{
  "name": "@wasao/kagemusha",
  "version": "0.1.1",
  "description": "Auto-update help center screenshots when your code changes. The shadow warrior for your documentation.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "kagemusha": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "bunx biome check .",
    "format": "bunx biome format --write .",
    "test": "bun test",
    "prepare": "husky",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "screenshot",
    "documentation",
    "help-center",
    "intercom",
    "playwright",
    "vrt",
    "visual-regression",
    "automation"
  ],
  "author": "iwasawahideto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iwasawahideto/kagemusha.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "glob": "^11.0.0",
    "inquirer": "^12.0.0",
    "odiff-bin": "^4.3.8",
    "playwright-chromium": "^1.50.0",
    "sharp": "^0.34.5",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "latest",
    "@types/inquirer": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.32.0",
    "husky": "^9.1.7",
    "typescript": "^5.7.0"
  }
}
