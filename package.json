{
  "name": "kagemusha",
  "version": "0.1.0",
  "description": "Auto-update help center screenshots when your code changes. The shadow warrior for your documentation.",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "kagemusha": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "screenshot",
    "documentation",
    "help-center",
    "intercom",
    "playwright",
    "vrt",
    "visual-regression",
    "automation"
  ],
  "author": "iwasawahideto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iwasawahideto/kagemusha.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "inquirer": "^12.0.0",
    "yaml": "^2.7.0",
    "glob": "^11.0.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "chalk": "^5.4.0"
  },
  "peerDependencies": {
    "playwright": "^1.50.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/inquirer": "^9.0.0",
    "playwright": "^1.50.0",
    "typescript": "^5.7.0"
  }
}
